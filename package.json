{
  "name": "@fookiejs/core",
  "version": "0.0.0",
  "description": "Model-driven backend framework with observable flows",
  "type": "module",
  "main": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "example": "tsx --tsconfig tsconfig.example.json example.ts",
    "test": "node --experimental-test-module-mocks --test \"tests/*.test.ts\"",
    "test:coverage": "node --experimental-test-module-mocks --test --experimental-test-coverage --test-coverage-include=src/index.ts --test-coverage-lines=99 --test-coverage-branches=97 --test-coverage-functions=98 \"tests/*.test.ts\"",
    "test:watch": "node --experimental-test-module-mocks --test --watch \"tests/*.test.ts\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "framework",
    "ddd",
    "workflow",
    "observability"
  ],
  "license": "MIT",
  "devDependencies": {
    "@fookiejs/eslint-plugin": "file:../eslint-plugin",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
